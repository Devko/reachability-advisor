{
  "schema_version": "1.0",
  "purpose": "Complex real-world application validation cases for end-to-end SBOM, Grype, source reachability, Terraform context, and visual graph output.",
  "cases": [
    {
      "id": "aws-retail-store-sample-app",
      "name": "AWS Containers Retail Store Sample App",
      "repo": "https://github.com/aws-containers/retail-store-sample-app.git",
      "web": "https://github.com/aws-containers/retail-store-sample-app",
      "worktree": "aws-retail-store-sample-app",
      "terraform_source": "terraform",
      "why_selected": "Large AWS sample with multiple deployable services, Java, Go, Node/TypeScript, Docker/Kubernetes assets, ECS/EKS/App Runner Terraform, databases, queues, secrets, IAM, and public/internal service paths.",
      "workloads": [
        {
          "artifact": "ui",
          "source": "src/ui",
          "aliases": ["public.ecr.aws/aws-containers/retail-store-sample-ui:1.5.0"]
        },
        {
          "artifact": "catalog",
          "source": "src/catalog",
          "aliases": ["public.ecr.aws/aws-containers/retail-store-sample-catalog:1.5.0"]
        },
        {
          "artifact": "carts",
          "source": "src/cart",
          "aliases": ["public.ecr.aws/aws-containers/retail-store-sample-cart:1.5.0"]
        },
        {
          "artifact": "checkout",
          "source": "src/checkout",
          "aliases": ["public.ecr.aws/aws-containers/retail-store-sample-checkout:1.5.0"]
        },
        {
          "artifact": "orders",
          "source": "src/orders",
          "aliases": ["public.ecr.aws/aws-containers/retail-store-sample-orders:1.5.0"]
        }
      ],
      "expectations": {
        "min_sboms": 5,
        "min_vulnerability_matches": 20,
        "min_findings": 10,
        "min_services_with_findings": 2,
        "min_terraform_resources": 10
      },
      "expected_limitations": [
        "Static HCL mode cannot expand Terraform modules, locals, dynamic blocks, or rendered Helm/Kubernetes child manifests.",
        "Artifact matching is strongest with a generated Terraform plan; source-only Terraform may leave some service image links as visibility gaps.",
        "Grype results depend on the local vulnerability database snapshot used by the validation runner."
      ]
    },
    {
