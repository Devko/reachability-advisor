{
  "version": 1,
  "description": "Sanitized provider-shaped policy examples for effective-access AST evaluation.",
  "cases": [
    {
      "name": "aws-cross-account-trust-with-org-condition",
      "provider": "aws",
      "record": {
        "provider": "aws",
        "identity": "arn:aws:iam::111111111111:role/cicd",
        "action": "sts:AssumeRole",
        "impact": "iam_escalation",
        "resource": "arn:aws:iam::222222222222:role/prod-api",
        "trust_policy": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": "arn:aws:iam::111111111111:role/cicd"
              },
              "Action": "sts:AssumeRole",
              "Resource": "arn:aws:iam::222222222222:role/prod-api",
              "Condition": {
                "StringEquals": {
                  "aws:PrincipalOrgID": "o-prod"
                }
              }
            }
          ]
        },
        "condition_context": {
          "aws:PrincipalOrgID": "o-prod"
        }
      },
      "expected": {
        "decision": "constrained_allow",
        "policy_layer": "trust_policy",
        "required_blocker": "condition",
        "matched_statements": 1,
        "principal_matched": true
      }
    },
    {
      "name": "aws-trust-principal-mismatch-denies-assume-role",
      "provider": "aws",
      "record": {
        "provider": "aws",
        "identity": "arn:aws:iam::111111111111:role/other",
        "action": "sts:AssumeRole",
        "impact": "iam_escalation",
        "resource": "arn:aws:iam::222222222222:role/prod-api",
        "trust_policy": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "AWS": "arn:aws:iam::111111111111:role/cicd"
              },
              "Action": "sts:AssumeRole",
              "Resource": "arn:aws:iam::222222222222:role/prod-api"
            }
          ]
        }
      },
      "expected": {
        "decision": "denied",
        "policy_layer": "trust_policy",
        "required_blocker": "trust_policy_deny",
        "matched_statements": 0
      }
    },
    {
      "name": "aws-permissions-boundary-blocks-identity-allow",
      "provider": "aws",
      "record": {
        "provider": "aws",
        "identity": "arn:aws:iam::111111111111:role/api",
        "action": "s3:DeleteObject",
        "impact": "data_access",
        "resource": "arn:aws:s3:::prod-bucket/private.txt",
        "identity_policy": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": "s3:*",
              "Resource": "arn:aws:s3:::prod-bucket/*"
            }
          ]
        },
        "permissions_boundary": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": "s3:GetObject",
              "Resource": "arn:aws:s3:::prod-bucket/*"
            }
          ]
        }
      },
      "expected": {
        "decision": "denied",
        "policy_layer": "permissions_boundary",
        "required_blocker": "permission_boundary",
        "matched_statements": 1
      }
    },
    {
      "name": "aws-service-control-policy-blocks-network-mutation",
      "provider": "aws",
      "record": {
        "provider": "aws",
        "identity": "arn:aws:iam::111111111111:role/network-automation",
        "action": "ec2:AuthorizeSecurityGroupIngress",
        "impact": "network_exposure",
        "resource": "arn:aws:ec2:eu-central-1:111111111111:security-group/sg-prod",
        "identity_policy": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": "ec2:AuthorizeSecurityGroupIngress",
              "Resource": "*"
            }
          ]
        },
        "service_control_policy": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": "ec2:Describe*",
              "Resource": "*"
            }
          ]
        }
      },
      "expected": {
        "decision": "denied",
        "policy_layer": "service_control_policy",
        "required_blocker": "scp_deny",
        "matched_statements": 1
      }
    },
    {
      "name": "aws-resource-policy-explicit-deny-overrides-identity-allow",
      "provider": "aws",
      "record": {
        "provider": "aws",
        "identity": "arn:aws:iam::111111111111:role/api",
        "action": "s3:GetObject",
        "impact": "data_access",
        "resource": "arn:aws:s3:::prod-bucket/private.txt",
        "identity_policy": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": "s3:GetObject",
              "Resource": "arn:aws:s3:::prod-bucket/*"
            }
          ]
        },
        "resource_policy": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Deny",
              "Principal": {
                "AWS": "arn:aws:iam::111111111111:role/api"
              },
              "Action": "s3:GetObject",
              "Resource": "arn:aws:s3:::prod-bucket/private.txt"
            }
          ]
        }
      },
      "expected": {
        "decision": "denied",
        "policy_layer": "resource_policy",
        "required_blocker": "resource_policy_deny",
        "matched_statements": 2
      }
    },
    {
      "name": "aws-cross-account-resource-policy-allows-external-role",
