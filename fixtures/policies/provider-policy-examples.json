              "Effect": "Allow",
              "Principal": {
                "AWS": "arn:aws:iam::111111111111:role/reporting"
              },
              "Action": "s3:GetObject",
              "Resource": "arn:aws:s3:::shared-bucket/*"
            }
          ]
        }
      },
      "expected": {
