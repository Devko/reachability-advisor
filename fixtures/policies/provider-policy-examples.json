    },
    {
      "name": "azure-deny-assignment-overrides-role-assignment",
      "provider": "azure",
      "record": {
        "provider": "azure",
        "identity": "principal-api",
        "action": "Microsoft.KeyVault/vaults/secrets/read",
        "impact": "data_access",
        "resource": "/subscriptions/sub-a/resourceGroups/rg-a/providers/Microsoft.KeyVault/vaults/v/secrets/api",
        "role_assignment": {
          "roleDefinitionName": "Key Vault Secrets User",
          "principalId": "principal-api",
          "scope": "/subscriptions/sub-a/resourceGroups/rg-a"
        },
        "deny_assignment": {
          "denyActions": [
            "Microsoft.KeyVault/vaults/secrets/read"
          ],
          "principalId": "principal-api",
          "scope": "/subscriptions/sub-a/resourceGroups/rg-a"
        }
      },
      "expected": {
        "decision": "denied",
        "policy_layer": "deny_assignment",
        "required_blockers": ["deny_assignment", "resource_group_scope"],
        "matched_statements": 2
      }
    },
    {
      "name": "gcp-secret-accessor-conditional-binding",
      "provider": "gcp",
      "record": {
        "provider": "gcp",
        "identity": "serviceAccount:api@prod.iam.gserviceaccount.com",
        "action": "secretmanager.versions.access",
        "impact": "data_access",
        "resource": "projects/prod/secrets/api",
        "iam_policy": {
          "bindings": [
            {
              "role": "roles/secretmanager.secretAccessor",
              "members": [
                "serviceAccount:api@prod.iam.gserviceaccount.com"
              ],
              "resources": [
                "projects/prod/secrets/api"
              ],
              "condition": {
                "title": "prod-secrets-only",
                "expression": "resource.name.startsWith('projects/prod/')"
              }
            }
          ]
        }
      },
      "expected": {
        "decision": "constrained_allow",
        "policy_layer": "iam_policy",
        "required_blocker": "conditional_iam_binding",
        "matched_statements": 1,
        "principal_matched": true
      }
    },
    {
      "name": "gcp-principal-access-boundary-blocks-cross-project-secret",
      "provider": "gcp",
      "record": {
        "provider": "gcp",
        "identity": "serviceAccount:api@prod.iam.gserviceaccount.com",
        "action": "secretmanager.versions.access",
        "impact": "data_access",
        "resource": "projects/prod/secrets/api",
        "iam_policy": {
          "bindings": [
            {
              "role": "roles/secretmanager.secretAccessor",
              "members": [
                "serviceAccount:api@prod.iam.gserviceaccount.com"
              ],
              "resources": [
                "projects/prod/secrets/api"
              ]
            }
          ]
        },
        "principal_access_boundary": {
          "permissions": [
            "secretmanager.versions.access"
          ],
          "resources": [
            "projects/dev/*"
          ]
        }
      },
      "expected": {
        "decision": "denied",
        "policy_layer": "principal_access_boundary",
        "required_blocker": "principal_access_boundary_deny",
        "matched_statements": 1,
        "principal_matched": true
      }
    },
