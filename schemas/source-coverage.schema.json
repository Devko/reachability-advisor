{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reachability Advisor Source Coverage",
  "type": "object",
  "required": ["schema_version", "summary", "artifacts"],
  "properties": {
    "schema_version": {"type": "string"},
    "summary": {
      "type": "object",
      "required": ["artifact_count", "files_scanned", "findings_analyzed", "source_evidence_coverage"],
      "properties": {
        "artifact_count": {"type": "integer", "minimum": 0},
        "artifacts_with_source_root": {"type": "integer", "minimum": 0},
        "files_scanned": {"type": "integer", "minimum": 0},
        "manifest_files_scanned": {"type": "integer", "minimum": 0},
        "files_skipped": {"type": "integer", "minimum": 0},
        "findings_analyzed": {"type": "integer", "minimum": 0},
        "findings_with_external_evidence": {"type": "integer", "minimum": 0},
        "findings_with_builtin_only_evidence": {"type": "integer", "minimum": 0},
        "findings_with_dependency_graph_path": {"type": "integer", "minimum": 0},
        "findings_with_manifest_evidence": {"type": "integer", "minimum": 0},
        "findings_with_package_specific_rule": {"type": "integer", "minimum": 0},
        "findings_with_rule_gap": {"type": "integer", "minimum": 0},
        "findings_with_weak_source_evidence": {"type": "integer", "minimum": 0},
        "critical_findings_requiring_query_family": {"type": "integer", "minimum": 0},
        "critical_findings_with_required_query_family": {"type": "integer", "minimum": 0},
        "critical_findings_missing_query_family": {"type": "integer", "minimum": 0},
        "source_diagnostic_counts": {"type": "object"},
        "source_evidence_coverage": {"type": "number", "minimum": 0, "maximum": 1},
        "source_rule_coverage": {"type": "number", "minimum": 0, "maximum": 1},
        "critical_query_family_coverage": {"type": "number", "minimum": 0, "maximum": 1},
        "external_evidence_records": {"type": "integer", "minimum": 0},
        "external_evidence_providers": {"type": "object"},
        "external_evidence_usable_ratio": {"type": "number", "minimum": 0, "maximum": 1},
        "external_evidence_selected_ratio": {"type": "number", "minimum": 0, "maximum": 1},
        "external_evidence_selector_diagnostics": {"type": "object"},
        "analysis_profile": {"enum": ["advisory", "production"]},
        "states": {"type": "object"}
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact", "files_scanned", "findings_analyzed", "states"],
        "properties": {
          "artifact": {"type": "string"},
          "source_root": {"type": ["string", "null"]},
          "source_root_exists": {"type": "boolean"},
          "files_scanned": {"type": "integer", "minimum": 0},
          "manifest_files_scanned": {"type": "integer", "minimum": 0},
          "files_skipped": {"type": "integer", "minimum": 0},
          "languages": {"type": "array", "items": {"type": "string"}},
          "findings_analyzed": {"type": "integer", "minimum": 0},
          "states": {"type": "object"},
          "source_diagnostics": {"type": "object"},
          "critical_query_family_coverage": {"type": "number", "minimum": 0, "maximum": 1},
          "skipped_files": {"type": "array"}
        }
      }
    },
    "production_readiness": {
      "type": "object",
      "properties": {
        "status": {"enum": ["advisory", "ready", "blocked"]},
        "blockers": {"type": "array", "items": {"type": "string"}},
        "source_mode": {"type": "string"},
        "deployment_evidence": {"type": "object"}
      },
      "additionalProperties": true
    },
    "notes": {"type": "array", "items": {"type": "string"}}
  }
}
