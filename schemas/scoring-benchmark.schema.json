{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reachability Advisor Scoring Benchmark",
  "type": "object",
  "required": ["schema_version", "cases"],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "1.0"},
    "description": {"type": "string"},
    "require_expected_decisions": {"type": "boolean"},
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "component", "vulnerability", "source", "context", "expected_tier"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "description": {"type": "string"},
          "artifact": {"type": "string"},
          "component": {"type": "object"},
          "vulnerability": {"type": "object"},
          "source": {"type": "object"},
          "context": {"type": "object"},
          "expected_tier": {"enum": ["urgent", "high", "medium", "low", "informational"]},
          "expected_decision": {
            "type": "object",
            "required": ["why", "required_reason_labels"],
            "properties": {
              "why": {"type": "string", "minLength": 1},
              "required_reason_labels": {
                "type": "array",
                "minItems": 1,
                "items": {"type": "string", "minLength": 1}
              }
            },
            "additionalProperties": false
          },
          "min_score": {"type": "number", "minimum": 0, "maximum": 100},
          "max_score": {"type": "number", "minimum": 0, "maximum": 100}
        }
      }
    }
  }
}
