{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reachability Advisor Runtime Policy",
  "type": "object",
  "required": ["fail_on_tier"],
  "additionalProperties": false,
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": "1.0"},
    "fail_on_tier": {"enum": ["urgent", "high", "medium", "low", "informational"]},
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reason"],
        "additionalProperties": false,
        "properties": {
          "vulnerability": {"type": "string", "minLength": 1},
          "artifact": {"type": "string", "minLength": 1},
          "component": {"type": "string", "minLength": 1},
          "expires": {"type": "string", "minLength": 1},
          "reason": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
