{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reachability Advisor Findings",
  "type": "object",
  "required": ["metadata", "findings"],
  "properties": {
    "metadata": {"type": "object"},
    "evidence_graph": {"type": "object"},
    "remediations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "artifact", "component", "vulnerability_count", "max_score", "tier"],
        "properties": {
          "key": {"type": "string"},
          "artifact": {"type": "object"},
          "component": {"type": "object"},
          "vulnerability_count": {"type": "integer", "minimum": 1},
          "max_score": {"type": "number", "minimum": 0, "maximum": 100},
          "tier": {"enum": ["urgent", "high", "medium", "low", "informational"]},
          "reachability": {"type": "string"},
          "reachability_label": {"type": "string"},
          "fix_available": {"type": "boolean"},
          "suggested_version": {"type": ["string", "null"]},
          "suggested_fix": {"type": ["string", "null"]},
          "candidate_fixed_versions": {"type": "array", "items": {"type": "string"}},
          "top_vulnerabilities": {"type": "array"}
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "artifact", "component", "vulnerability", "score", "tier", "source_reachability"],
        "properties": {
          "key": {"type": "string"},
          "finding_type": {"enum": ["dependency_vulnerability", "code_weakness"]},
          "score": {"type": "number", "minimum": 0, "maximum": 100},
          "tier": {"enum": ["urgent", "high", "medium", "low", "informational"]},
          "artifact": {"type": "object"},
          "component": {"type": "object"},
          "vulnerability": {"type": "object"},
          "weakness": {"type": "object"},
          "source_reachability": {
            "type": "object",
            "required": ["state", "label"],
            "properties": {
              "state": {
                "enum": [
                  "absent",
                  "unknown_due_to_no_rule",
                  "package_present",
                  "dependency_reachable",
                  "imported",
                  "function_reachable",
                  "attacker_controlled"
                ]
              },
              "label": {"type": "string"},
              "confidence": {"enum": ["high", "medium", "low"]},
              "language": {"type": "string"},
              "reason": {"type": "string"},
              "matched_symbols": {"type": "array", "items": {"type": "string"}},
              "dependency_path": {"type": "array", "items": {"type": "string"}},
              "evidence_source": {"type": "string"},
              "diagnostics": {"type": "array", "items": {"type": "object"}},
              "locations": {"type": "array"}
            }
          },
          "context": {"type": "object"},
          "scoring": {
            "type": "object",
            "properties": {
              "model_version": {"type": "string"},
              "dimensions": {"type": "array", "items": {"type": "object"}},
              "gates": {"type": "array", "items": {"type": "object"}},
              "final_score": {"type": "number", "minimum": 0, "maximum": 100},
              "tier": {"enum": ["urgent", "high", "medium", "low", "informational"]}
            }
          },
          "rationale": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
