{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reachability Advisor Security Evidence",
  "type": "object",
  "required": ["security_evidence"],
  "properties": {
    "security_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "weakness"],
        "properties": {
          "scanner_type": {"enum": ["sast", "dast"]},
          "tool": {"type": "string"},
          "artifact": {"type": "string"},
          "rule_id": {"type": "string"},
          "weakness": {"type": "string"},
          "cwe": {"type": "string"},
          "severity": {"type": "string"},
          "cvss": {"type": "number", "minimum": 0, "maximum": 10},
          "confidence": {"enum": ["high", "medium", "low"]},
          "source": {"type": "object"},
          "sink": {"type": "object"},
          "method": {"type": "string"},
          "parameter": {"type": "string"},
          "url": {"type": "string"},
          "route": {"type": "string"},
          "authentication_context": {"type": "string"},
          "request_evidence": {"type": "string"},
          "response_evidence": {"type": "string"},
          "evidence": {"type": ["object", "array", "string"]},
          "remediation": {"type": "string"},
          "references": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    }
  }
}
