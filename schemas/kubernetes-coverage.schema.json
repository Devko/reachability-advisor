{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reachability Advisor Kubernetes Manifest Coverage",
  "type": "object",
  "required": ["schema_version", "summary", "resources", "unmatched_artifacts", "notes"],
  "properties": {
    "schema_version": {"type": "string"},
    "summary": {
      "type": "object",
      "required": ["manifest_files_scanned", "total_resources", "artifacts_requested", "artifacts_matched", "artifact_match_coverage"],
      "properties": {
        "manifest_files_scanned": {"type": "integer", "minimum": 0},
        "total_resources": {"type": "integer", "minimum": 0},
        "workload_resources": {"type": "integer", "minimum": 0},
        "service_resources": {"type": "integer", "minimum": 0},
        "ingress_resources": {"type": "integer", "minimum": 0},
        "network_policy_resources": {"type": "integer", "minimum": 0},
        "rbac_resources": {"type": "integer", "minimum": 0},
        "artifacts_requested": {"type": "integer", "minimum": 0},
        "artifacts_matched": {"type": "integer", "minimum": 0},
        "artifact_match_coverage": {"type": "number", "minimum": 0, "maximum": 1},
        "contexts_generated": {"type": "integer", "minimum": 0},
        "exposure_counts": {"type": "object"},
        "privilege_counts": {"type": "object"}
      }
    },
    "resources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "document_index", "kind", "name", "namespace", "address"],
        "properties": {
          "path": {"type": "string"},
          "document_index": {"type": "integer", "minimum": 0},
          "kind": {"type": "string"},
          "name": {"type": "string"},
          "namespace": {"type": "string"},
          "address": {"type": "string"}
        }
      }
    },
    "unmatched_artifacts": {"type": "array", "items": {"type": "string"}},
    "notes": {"type": "array", "items": {"type": "string"}}
  }
}
