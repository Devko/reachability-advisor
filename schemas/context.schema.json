{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reachability Advisor Context",
  "type": "object",
  "properties": {
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "environment": {"type": "string"},
          "exposure": {"type": "string"},
          "privilege": {"type": "string"},
          "criticality": {"type": "string"},
          "iam_impacts": {"type": "array", "items": {"type": "string"}},
          "iam_capabilities": {"type": "array", "items": {"type": "object"}},
          "effective_access": {"type": "array", "items": {"type": "object"}},
          "effective_exposure": {"type": "array", "items": {"type": "object"}},
          "network_paths": {"type": "array", "items": {"type": "object"}},
          "owner": {"type": "string"},
          "confidence": {"enum": ["high", "medium", "low"]},
          "evidence": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
