{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/reachability-advisor/schemas/sbom-plan.schema.json",
  "title": "Reachability Advisor SBOM Plan",
  "type": "object",
  "required": ["schema_version", "artifact", "commands"],
  "properties": {
    "schema_version": {"type": "string"},
    "artifact": {"type": "string"},
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool", "purpose", "command", "output"],
        "properties": {
          "tool": {"type": "string"},
          "purpose": {"type": "string"},
          "command": {"type": "string"},
          "output": {"type": "string"},
          "notes": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
