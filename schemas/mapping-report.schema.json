{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/reachability-advisor/schemas/mapping-report.schema.json",
  "title": "Reachability Advisor Mapping Report",
  "type": "object",
  "required": ["schema_version", "summary", "artifacts"],
  "properties": {
    "schema_version": {"type": "string"},
    "summary": {
      "type": "object",
      "properties": {
        "artifact_count": {"type": "integer", "minimum": 0},
        "artifacts_with_source_roots": {"type": "integer", "minimum": 0},
        "artifacts_with_terraform_matches": {"type": "integer", "minimum": 0},
        "artifacts_with_strong_identity": {"type": "integer", "minimum": 0},
        "unmatched_terraform_artifacts": {"type": "array"}
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "component_count", "artifact_candidates", "source_root_exists", "terraform_matched", "mapping_warnings"],
        "properties": {
          "name": {"type": "string"},
          "version": {"type": ["string", "null"]},
          "reference": {"type": ["string", "null"]},
          "sbom_path": {"type": "string"},
          "component_count": {"type": "integer", "minimum": 0},
          "artifact_candidates": {"type": "array", "items": {"type": "string"}},
          "artifact_identity": {
            "type": "object",
            "properties": {
              "candidates": {"type": "array"},
              "warnings": {"type": "array", "items": {"type": "string"}}
            },
            "additionalProperties": true
          },
          "source_root": {"type": ["string", "null"]},
          "source_root_exists": {"type": "boolean"},
          "terraform_matched": {"type": "boolean"},
          "terraform_matches": {"type": "array"},
          "mapping_warnings": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    },
    "terraform_coverage_summary": {"type": "object"}
  },
  "additionalProperties": true
}
